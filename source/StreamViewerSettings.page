<script>
(function () {
'use strict';

// ══════════════════════════════════════════════════════════════════════════════
// CONSTANTS
// ══════════════════════════════════════════════════════════════════════════════

var PLEX_TV_API  = 'https://plex.tv/api/v2/resources?includeHttps=1&includeRelay=1&includeIPv6=1';
var PLEX_HEADERS = {
    'Accept':                  'application/json',
    'X-Plex-Product':          'Stream Viewer',
    'X-Plex-Version':          '1.0',
    'X-Plex-Client-Identifier':'streamviewer-unraid-settings',
};

var SV_TYPES = {
    plex:     { label: 'Plex',     color: '#e5a00d' },
    jellyfin: { label: 'Jellyfin', color: '#00a4dc' },
    emby:     { label: 'Emby',     color: '#52b54b' },
};

// ══════════════════════════════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════════════════════════════

var cards = [];  // [{cardIndex, removed, data}]

// ══════════════════════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════════════════════

function escHtml(s) {
    return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function markDirty() {
    var apply = document.querySelector('input[name="#apply_btn"]');
    if (!apply) return;
    apply.disabled = false;
    if (typeof window.checkChanges === 'function') { try { window.checkChanges(); } catch(_) {} }
}

// ══════════════════════════════════════════════════════════════════════════════
// PLEX OAUTH PIN FLOW  — ALL plex.tv calls go through PHP (avoids CORS + Origin)
//
// Flow:
//  1. JS  → PHP plex_create_pin  → PHP POSTs to plex.tv/api/v2/pins (no Origin)
//  2. PHP returns {pin_id, auth_url}, JS opens auth_url popup
//  3. JS polls PHP plex_poll_pin every 2s
//  4. PHP polls plex.tv/api/v2/pins/{id} — when ready, runs discovery
//  5. PHP returns server list, account token NEVER leaves PHP
// ══════════════════════════════════════════════════════════════════════════════

var _plexPollTimer  = null;
var _plexAuthWindow = null;
var _plexPinId      = null;
var _plexPollCount  = 0;
var PLEX_POLL_MAX   = 120;   // 120 × 2s = 4 minutes
var PLEX_POLL_MS    = 2000;
var SV_API          = '/plugins/streamviewer/streamviewer_api.php';

var PLEX_BTN_LABEL  = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="vertical-align:middle;margin-right:.4rem;"><path d="M11.69 3 5 12l6.69 9h1.55l-6.69-9 6.69-9zM17.31 3h-1.55l-6.69 9 6.69 9h1.55l-6.69-9z"/></svg>Connect with Plex';

function plexResetBtn() {
    var btn = document.getElementById('svPlexSignInBtn');
    if (btn) { btn.disabled = false; btn.innerHTML = PLEX_BTN_LABEL; }
}

function plexShowStep(step) {
    var s1 = document.getElementById('svPlexOauthStep1');
    var s2 = document.getElementById('svPlexOauthStep2');
    if (s1) s1.style.display = step === 1 ? 'flex' : 'none';
    if (s2) s2.style.display = step === 2 ? 'flex' : 'none';
}

/** Step 1 — ask PHP to create the PIN, then open the auth popup. */
function startPlexOauth() {
    var btn   = document.getElementById('svPlexSignInBtn');
    var errEl = document.getElementById('svDiscoveryError');
    var resEl = document.getElementById('svDiscoveryResults');

    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Connecting…';
    errEl.style.display = 'none';
    if (resEl) resEl.style.display = 'none';

    // PHP creates the PIN server-side — no Origin header sent to plex.tv
    $.ajax({
        url:      SV_API,
        method:   'GET',
        data:     { action: 'plex_create_pin', forward_url: window.location.href.split('#')[0], _svt: window.svToken || '' },
        headers:  { 'X-Requested-With': 'XMLHttpRequest' },
        timeout:  12000,
        dataType: 'json',
        success: function(data) {
            if (!data.ok) {
                plexResetBtn();
                showDiscoveryError(data.error || 'Could not create PIN');
                return;
            }

            _plexPinId     = data.pin_id;
            _plexPollCount = 0;

            // Open Plex auth popup — URL was built by PHP
            _plexAuthWindow = window.open(
                data.auth_url, 'plex_auth',
                'width=800,height=700,left=' + Math.round((screen.width  - 800) / 2)
                + ',top=' + Math.round((screen.height - 700) / 2)
            );

            plexShowStep(2);
            setOauthMsg('Waiting for you to sign in at plex.tv…');
            _plexPollTimer = setInterval(pollPlexPin, PLEX_POLL_MS);
        },
        error: function(xhr) {
            plexResetBtn();
            var msg = (xhr.responseJSON && xhr.responseJSON.error) ? xhr.responseJSON.error : 'Could not reach plex.tv';
            showDiscoveryError(msg);
        },
    });
}

/** Step 3 — poll PHP which polls plex.tv server-side. */
function pollPlexPin() {
    _plexPollCount++;

    if (_plexPollCount > PLEX_POLL_MAX) {
        cancelPlexOauth();
        showDiscoveryError('Sign-in timed out. Please try again.');
        return;
    }

    var remaining = Math.ceil((PLEX_POLL_MAX - _plexPollCount) * PLEX_POLL_MS / 1000);
    setOauthMsg('Waiting for plex.tv sign-in… (' + remaining + 's remaining)');

    $.ajax({
        url:      SV_API,
        method:   'GET',
        data:     { action: 'plex_poll_pin', pin_id: _plexPinId, _svt: window.svToken || '' },
        headers:  { 'X-Requested-With': 'XMLHttpRequest' },
        timeout:  8000,
        dataType: 'json',
        success: function(data) {
            if (!data.ok) {
                // transient error — keep polling
                return;
            }

            if (!data.ready) {
                // Not yet authorized — keep polling
                return;
            }

            // Authorized! PHP already ran discovery and returned servers.
            clearInterval(_plexPollTimer);
            _plexPollTimer = null;
            if (_plexAuthWindow) { try { _plexAuthWindow.close(); } catch(_) {} _plexAuthWindow = null; }

            plexShowStep(1);
            plexResetBtn();

            if (!data.servers || data.servers.length === 0) {
                showDiscoveryError('No Plex Media Servers found on this account.');
                return;
            }

            renderDiscoveryResults(data.servers);
        },
        error: function() {
            // network hiccup — keep polling
        },
    });
}

function cancelPlexOauth() {
    if (_plexPollTimer)  { clearInterval(_plexPollTimer); _plexPollTimer = null; }
    if (_plexAuthWindow) { try { _plexAuthWindow.close(); } catch(_) {} _plexAuthWindow = null; }
    plexShowStep(1);
    plexResetBtn();
}

function setOauthMsg(html) {
    var el = document.getElementById('svPlexOauthMsg');
    if (el) el.innerHTML = html;
}

function showDiscoveryError(msg) {
    var el = document.getElementById('svDiscoveryError');
    if (!el) return;
    el.textContent = '✗ ' + msg;
    el.style.display = '';
}

function classifyConnection(conn) {
    if (conn.relay) {
        return { label: 'Relay — via plex.tv (recommended)', priority: 1, tag: 'relay' };
    }
    if (!conn.local) {
        return { label: 'Remote — ' + conn.address + ':' + conn.port, priority: 2, tag: 'remote' };
    }
    return { label: 'Local — ' + conn.address + ':' + conn.port, priority: 3, tag: 'local' };
}

/**
 * Render the discovery results — one card per found Plex server.
 * Each card has a connection dropdown and an "Add" button.
 */
function renderDiscoveryResults(servers) {
    var resultsEl = document.getElementById('svDiscoveryResults');
    var headerEl  = document.getElementById('svDiscoveryHeader');
    var listEl    = document.getElementById('svDiscoveryList');
    if (!resultsEl || !listEl) return;

    headerEl.innerHTML = '<div class="sv-discovery-found">'
        + '<i class="fa fa-check-circle" style="color:#52b54b;"></i> '
        + 'Found <strong>' + servers.length + '</strong> server' + (servers.length !== 1 ? 's' : '')
        + '</div>';

    listEl.innerHTML = servers.map(function(srv, idx) {
        return buildDiscoveryCard(srv, idx);
    }).join('');

    // Bind Add buttons
    listEl.querySelectorAll('.sv-disc-add-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            addDiscoveredServer(btn, servers);
        });
    });

    resultsEl.style.display = '';
}

function buildDiscoveryCard(srv, idx) {
    var connections = (srv.connections || []).filter(function(c) { return c.uri; });
    if (connections.length === 0) {
        return '<div class="sv-disc-card sv-disc-card--unavailable">'
            + '<span class="sv-disc-name">' + escHtml(srv.name) + '</span>'
            + '<span class="sv-disc-unavail">No connections available</span>'
            + '</div>';
    }

    // Sort connections: relay first, then remote, then local
    var sorted = connections.slice().sort(function(a, b) {
        return classifyConnection(a).priority - classifyConnection(b).priority;
    });

    var options = sorted.map(function(conn, i) {
        var cls = classifyConnection(conn);
        return '<option value="' + escHtml(conn.uri) + '"' + (i === 0 ? ' selected' : '') + '>'
            + escHtml(cls.label) + '</option>';
    }).join('');

    var isOwned  = srv.owned ? '' : ' <span class="sv-disc-shared">(shared)</span>';
    var alreadyAdded = cards.some(function(c) {
        return !c.removed && c.data.name === srv.name && c.data.type === 'plex';
    });

    return '<div class="sv-disc-card" data-srv-idx="' + idx + '">'
        + '<div class="sv-disc-card-top">'
        +   '<span class="sv-disc-name">' + escHtml(srv.name) + isOwned + '</span>'
        +   (alreadyAdded ? '<span class="sv-disc-already">✓ added</span>' : '')
        + '</div>'
        + '<div class="sv-disc-card-bottom">'
        +   '<select class="form-control sv-disc-conn-select" data-srv-idx="' + idx + '" data-srv-token="' + escHtml(srv.accessToken || '') + '" data-srv-name="' + escHtml(srv.name) + '">'
        +     options
        +   '</select>'
        +   '<button type="button" class="sv-disc-add-btn sv-add-btn" data-srv-idx="' + idx + '"'
        +     (alreadyAdded ? ' disabled' : '') + '>'
        +     '<i class="fa fa-plus"></i> Add'
        +   '</button>'
        + '</div>'
        + '</div>';
}

function addDiscoveredServer(btn, servers) {
    var idx   = parseInt(btn.dataset.srvIdx, 10);
    var srv   = servers[idx];
    if (!srv) return;

    var select = document.querySelector('.sv-disc-conn-select[data-srv-idx="' + idx + '"]');
    var url    = select ? select.value : '';

    if (!url) { alert('No connection URL selected.'); return; }

    var active = cards.filter(function(c) { return !c.removed; });
    if (active.length >= window.svMaxServers) {
        alert('Maximum ' + window.svMaxServers + ' servers reached. Remove one first.');
        return;
    }

    addCard({
        type:              'plex',
        name:              srv.name || 'Plex Server',
        url:               url,
        enabled:           true,
        has_token:         !!(srv.accessToken),
        // accessToken = server-specific token from plex.tv discovery
        // this is what the PHP API uses — NOT the account token
        token_placeholder: srv.accessToken || '',
    });

    // Mark as added in the discovery card
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-check"></i> Added';
    var already = btn.closest('.sv-disc-card');
    if (already && !already.querySelector('.sv-disc-already')) {
        var top = already.querySelector('.sv-disc-card-top');
        if (top) {
            var span = document.createElement('span');
            span.className = 'sv-disc-already';
            span.textContent = '✓ added';
            top.appendChild(span);
        }
    }

    markDirty();
}

// ══════════════════════════════════════════════════════════════════════════════
// JELLYFIN / EMBY MANUAL ADD
// ══════════════════════════════════════════════════════════════════════════════

function addJellyfinServer() {
    var type  = 'jellyfin';
    var name  = $.trim((document.getElementById('svJfName')  || {}).value || '');
    var url   = $.trim((document.getElementById('svJfUrl')   || {}).value || '');
    var token = $.trim((document.getElementById('svJfToken') || {}).value || '');

    if (!url)   { alert('Please enter the server URL.');  return; }
    if (!token) { alert('Please enter the API key.');     return; }
    if (!name)  name = 'Jellyfin Server';

    var active = cards.filter(function(c) { return !c.removed; });
    if (active.length >= window.svMaxServers) {
        alert('Maximum ' + window.svMaxServers + ' servers reached.');
        return;
    }

    addCard({
        type:              type,
        name:              name,
        url:               url.replace(/\/$/, ''),
        enabled:           true,
        has_token:         true,
        token_placeholder: token,
    });

    // Clear the form
    document.getElementById('svJfName').value  = '';
    document.getElementById('svJfUrl').value   = '';
    document.getElementById('svJfToken').value = '';

    var res = document.getElementById('svJfTestResult');
    if (res) res.style.display = 'none';

    markDirty();
}

function testJellyfinServer() {
    var type  = 'jellyfin';
    var url   = ((document.getElementById('svJfUrl')   || {}).value  || '').replace(/\/$/, '');
    var token = (document.getElementById('svJfToken') || {}).value  || '';
    var btn   = document.getElementById('svJfTestBtn');
    var res   = document.getElementById('svJfTestResult');

    // Brief flash: hide result so re-click is always visible
    if (res) res.style.display = 'none';

    if (!url || !token) {
        setTimeout(function() { showResult(res, false, 'Fill in URL and API Key first.'); }, 60);
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Testing…';

    $.ajax({
        url:      '/plugins/streamviewer/streamviewer_api.php',
        method:   'GET',
        timeout:  12000,
        headers:  { 'X-Requested-With': 'XMLHttpRequest' },
        data: {
            action:     'test_connection',
            type:       type,
            url:        url,
            token:      token,
            _svt:       window.svToken || '',
        },
        dataType: 'json',
        success: function(data) {
            if (data.ok) {
                var ver = data.version ? ' (v' + data.version + ')' : '';
                showResult(res, true, 'Connected to ' + (data.server || type) + ver);
            } else {
                showResult(res, false, data.error || 'Connection failed');
            }
        },
        error: function(xhr) {
            var msg = (xhr.responseJSON && xhr.responseJSON.error) ? xhr.responseJSON.error : 'Request failed';
            showResult(res, false, msg);
        },
        complete: function() {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-plug"></i> Test Connection';
        },
    });
}

// ══════════════════════════════════════════════════════════════════════════════
// CONFIGURED SERVERS LIST
// ══════════════════════════════════════════════════════════════════════════════

function addCard(data) {
    var ci = Date.now() + Math.floor(Math.random() * 1000);
    cards.push({ cardIndex: ci, removed: false, data: data });
    renderAllCards();
}

function buildServerCard(data, cardIndex) {
    var type    = data.type    || '';
    var name    = data.name    || '';
    var url     = data.url     || '';
    var enabled = data.enabled !== false;
    var hasToken= data.has_token || false;
    var tokenPh = data.token_placeholder || '';
    var typeMeta = SV_TYPES[type] || { label: type, color: '#fff' };
    var enabledClass = enabled ? ' sv-server-card--enabled' : '';

    // For plex: token is from discovery (read-only hint), URL is read-only
    // For jf/emby: fully editable
    var urlReadonly    = type === 'plex' ? ' readonly title="Discovered via plex.tv"' : '';
    var tokenReadonly  = type === 'plex' ? ' readonly title="Server token from plex.tv discovery"' : '';
    var tokenPlaceholder = type === 'plex'
        ? (hasToken ? 'Server token stored (from plex.tv discovery)' : '')
        : (hasToken ? 'Token saved — type to replace' : 'Paste your API key here');

    return '<div class="sv-server-card' + enabledClass + '" data-card-index="' + cardIndex + '">'
        + '<div class="sv-server-card-hd">'
        +   '<label class="sv-server-toggle">'
        +     '<input type="checkbox" class="sv-srv-enabled"' + (enabled ? ' checked' : '') + '>'
        +     '<span class="sv-server-badge-type" style="background:' + typeMeta.color + '22;color:' + typeMeta.color + ';border:1px solid ' + typeMeta.color + '44;font-size:.72em;font-weight:700;padding:.1em .45em;border-radius:3px;margin-right:.4rem;">' + escHtml(typeMeta.label) + '</span>'
        +     '<span class="sv-server-toggle-label">' + escHtml(name || 'New Server') + '</span>'
        +   '</label>'
        +   '<div class="sv-server-card-actions">'
        +     '<button type="button" class="sv-remove-btn" title="Remove server">Remove</button>'
        +   '</div>'
        + '</div>'
        + '<div class="sv-server-card-bd">'
        +   '<div class="sv-server-fields">'
        +     '<div class="sv-server-field">'
        +       '<label class="sv-field-label">Type</label>'
        +       '<input type="text" class="form-control sv-srv-type-display" value="' + escHtml(typeMeta.label) + '" readonly style="opacity:.6;cursor:default;">'
        +       '<input type="hidden" class="sv-srv-type" value="' + escHtml(type) + '">'
        +     '</div>'
        +     '<div class="sv-server-field">'
        +       '<label class="sv-field-label">Display Name</label>'
        +       '<input type="text" class="form-control sv-srv-name" maxlength="64" value="' + escHtml(name) + '">'
        +     '</div>'
        +     '<div class="sv-server-field sv-server-field--wide">'
        +       '<label class="sv-field-label">Server URL'
        +         (type === 'plex' ? ' <span class="sv-token-saved" style="color:#e5a00d;">plex.tv discovery</span>' : '') + '</label>'
        +       '<input type="text" class="form-control sv-srv-url" value="' + escHtml(url) + '"' + urlReadonly + '>'
        +     '</div>'
        +     '<div class="sv-server-field sv-server-field--wide">'
        +       '<label class="sv-field-label">Token / API Key'
        +         (hasToken ? ' <span class="sv-token-saved">✓ saved</span>' : '') + '</label>'
        +       '<input type="password" class="form-control sv-srv-token"'
        +         ' placeholder="' + escHtml(tokenPlaceholder) + '"'
        +         ' value="' + escHtml(tokenPh) + '"'
        +         ' autocomplete="new-password"' + tokenReadonly + '>'
        +     '</div>'
        +   '</div>'
        + '</div>'
        + '</div>';
}

function renderAllCards() {
    renderListForType('plex',     'svPlexServerList',  'svPlexCountPill');
    renderListForType('jellyfin', 'svJfServerList',    'svJfCountPill');
    renderListForType('emby',     'svEmbyServerList',  'svEmbyCountPill');
    updateCountPill();
}

function renderListForType(type, listId, pillId) {
    var list = document.getElementById(listId);
    if (!list) return;
    var active = cards.filter(function(c) { return !c.removed && c.data.type === type; });
    if (active.length === 0) {
        list.innerHTML = '<div class="sv-no-servers">No ' + type + ' servers configured yet.</div>';
    } else {
        list.innerHTML = active.map(function(c) { return buildServerCard(c.data, c.cardIndex); }).join('');
    }
    var pill = document.getElementById(pillId);
    if (pill) pill.textContent = 'Servers ' + active.length;
    bindCardEventsIn(list);
}

function bindCardEventsIn(list) {
    if (!list) return;
    list.querySelectorAll('.sv-srv-enabled').forEach(function(cb) {
        cb.addEventListener('change', function() {
            this.closest('.sv-server-card').classList.toggle('sv-server-card--enabled', this.checked);
            markDirty();
        });
    });
    list.querySelectorAll('.sv-srv-name').forEach(function(inp) {
        inp.addEventListener('input', function() {
            var label = this.closest('.sv-server-card').querySelector('.sv-server-toggle-label');
            if (label) label.textContent = this.value || 'New Server';
            markDirty();
        });
    });
    list.querySelectorAll('.sv-remove-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var ci    = parseInt(this.closest('.sv-server-card').dataset.cardIndex, 10);
            var entry = cards.find(function(c) { return c.cardIndex === ci; });
            if (entry) entry.removed = true;
            renderAllCards();
            markDirty();
        });
    });
}

function updateCountPill() {
    var pill   = document.getElementById('svServerCountPill');
    var active = cards.filter(function(c) { return !c.removed; }).length;
    if (pill) pill.textContent = active + ' / ' + window.svMaxServers;
}

// ══════════════════════════════════════════════════════════════════════════════
// RESULT DISPLAY HELPER
// ══════════════════════════════════════════════════════════════════════════════

function showResult(el, ok, msg) {
    if (!el) return;
    msg = msg || '';

    // Detect network errors that suggest ipvlan/macvlan host isolation
    var networkHint = '';
    if (!ok) {
        var lower = msg.toLowerCase();
        if (lower.indexOf('no route to host') !== -1
            || lower.indexOf('could not connect') !== -1
            || lower.indexOf('failed to connect') !== -1
            || lower.indexOf('connection refused') !== -1
            || lower.indexOf('timed out') !== -1) {
            networkHint = '\n💡 If your media server uses a custom Docker network (ipvlan/macvlan), '
                + 'you need to enable: Settings → Docker → Host access to custom networks. '
                + '(Stop Docker first, switch to Advanced View.)';
        }
    }

    el.textContent = (ok ? '✓ ' : '✗ ') + msg + networkHint;
    el.className   = 'sv-inline-result ' + (ok ? 'sv-test-ok' : 'sv-test-err');
    if (networkHint) el.style.whiteSpace = 'pre-line';
    else el.style.whiteSpace = '';
    el.style.display = '';
}

// ══════════════════════════════════════════════════════════════════════════════
// EMBY ADD / TEST
// ══════════════════════════════════════════════════════════════════════════════

function testEmbyServer() {
    var url   = ((document.getElementById('svEmbyUrl')   || {}).value || '').replace(/\/$/, '');
    var token = (document.getElementById('svEmbyToken') || {}).value || '';
    var btn   = document.getElementById('svEmbyTestBtn');
    var res   = document.getElementById('svEmbyTestResult');

    // Brief flash: hide result so re-click is always visible
    if (res) res.style.display = 'none';

    if (!url || !token) {
        setTimeout(function() { showResult(res, false, 'URL and API Key are required.'); }, 60);
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Testing…';

    $.ajax({
        url:      SV_API,
        method:   'GET',
        timeout:  12000,
        headers:  { 'X-Requested-With': 'XMLHttpRequest' },
        data: {
            action: 'test_connection',
            type:   'emby',
            url:    url,
            token:  token,
            _svt:   window.svToken || '',
        },
        dataType: 'json',
        success: function(d) {
            var ver = d.version ? ' (v' + d.version + ')' : '';
            showResult(res, d.ok, d.ok ? 'Connected!' + ver : (d.error || 'Failed'));
        },
        error: function(xhr) {
            var msg = (xhr.responseJSON && xhr.responseJSON.error) ? xhr.responseJSON.error : 'Request failed';
            showResult(res, false, msg);
        },
        complete: function() {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-plug"></i> Test Connection';
        },
    });
}

function addEmbyServer() {
    var name  = $.trim((document.getElementById('svEmbyName')  || {}).value || '');
    var url   = $.trim((document.getElementById('svEmbyUrl')   || {}).value || '');
    var token = $.trim((document.getElementById('svEmbyToken') || {}).value || '');
    var res   = document.getElementById('svEmbyTestResult');
    if (!name)  { showResult(res, false, 'Display Name is required.'); return; }
    if (!url)   { showResult(res, false, 'Server URL is required.'); return; }
    if (!token) { showResult(res, false, 'API Key is required.'); return; }
    if (cards.filter(function(c){ return !c.removed; }).length >= window.svMaxServers) {
        showResult(res, false, 'Maximum ' + window.svMaxServers + ' servers reached.'); return;
    }

    addCard({
        type:              'emby',
        name:              name,
        url:               url.replace(/\/$/, ''),
        enabled:           true,
        has_token:         true,
        token_placeholder: token,
    });

    document.getElementById('svEmbyName').value  = '';
    document.getElementById('svEmbyUrl').value   = '';
    document.getElementById('svEmbyToken').value = '';
    if (res) res.style.display = 'none';
    markDirty();
}

// ══════════════════════════════════════════════════════════════════════════════
// SYNC CARDS → HIDDEN INPUTS  (called before form submit)
// ══════════════════════════════════════════════════════════════════════════════

function syncAllToHidden() {
    // Read current DOM state from all type-specific lists
    ['svPlexServerList','svJfServerList','svEmbyServerList'].forEach(function(listId) {
        var list = document.getElementById(listId);
        if (!list) return;
        list.querySelectorAll('.sv-server-card').forEach(function(cardEl) {
            var ci = parseInt(cardEl.dataset.cardIndex, 10);
            var entry = cards.find(function(c) { return c.cardIndex === ci; });
            if (!entry) return;
            entry.data.enabled           = !!(cardEl.querySelector('.sv-srv-enabled') || {}).checked;
            entry.data.type              = (cardEl.querySelector('.sv-srv-type') || {}).value  || entry.data.type;
            entry.data.name              = (cardEl.querySelector('.sv-srv-name')  || {}).value || entry.data.name;
            entry.data.url               = (cardEl.querySelector('.sv-srv-url')   || {}).value || entry.data.url;
            var tok = (cardEl.querySelector('.sv-srv-token') || {}).value || '';
            if (tok) { entry.data.token_placeholder = tok; entry.data.has_token = true; }
        });
    });

    var active = cards.filter(function(c) { return !c.removed; });

    for (var slot = 1; slot <= window.svMaxServers; slot++) {
        var card = active[slot - 1];
        var en   = document.getElementById('svHidEnabled' + slot);
        var typ  = document.getElementById('svHidType'    + slot);
        var nam  = document.getElementById('svHidName'    + slot);
        var url  = document.getElementById('svHidUrl'     + slot);
        var tok  = document.getElementById('svHidToken'   + slot);

        if (card) {
            if (en)  en.value  = card.data.enabled ? '1' : '0';
            if (typ) typ.value = card.data.type    || '';
            if (nam) nam.value = card.data.name    || '';
            if (url) url.value = card.data.url     || '';
            if (tok) {
                var t = card.data.token_placeholder || '';
                // If token is unchanged sentinel OR is the raw token, pass it through
                tok.value = t;
            }
        } else {
            if (en)  en.value  = '0';
            if (typ) typ.value = '';
            if (nam) nam.value = '';
            if (url) url.value = '';
            if (tok) tok.value = '';
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// TABS
// ══════════════════════════════════════════════════════════════════════════════

function setTab(which) {
    var tabMap = {
        widget:   { tab: 'svTabWidget',   panel: 'svWidgetPanel'   },
        plex:     { tab: 'svTabPlex',     panel: 'svPlexPanel'     },
        jellyfin: { tab: 'svTabJellyfin', panel: 'svJellyfinPanel' },
        emby:     { tab: 'svTabEmby',     panel: 'svEmbyPanel'     },
    };
    Object.keys(tabMap).forEach(function(t) {
        var tab   = document.getElementById(tabMap[t].tab);
        var panel = document.getElementById(tabMap[t].panel);
        if (tab)   tab.classList.toggle('active', t === which);
        if (panel) panel.style.display = (t === which) ? '' : 'none';
    });
    var inp = document.getElementById('svActiveTabInput');
    if (inp) inp.value = which;
    // Update Reset button label per tab
    var resetBtn = document.getElementById('svResetBtn');
    if (resetBtn) {
        resetBtn.style.display = '';
        resetBtn.value = (which === 'widget') ? 'Reset to Defaults' : 'Clear Form';
    }
    try { sessionStorage.setItem('sv_active_tab', which); } catch(_) {}
    try { history.replaceState(null, '', '#' + which); } catch(_) {}
}

// ══════════════════════════════════════════════════════════════════════════════
// RESET TO DEFAULTS
// ══════════════════════════════════════════════════════════════════════════════

function resetDefaults() {
    var form = document.querySelector('form[name="streamviewer_settings"]');
    if (!form) return;
    var activeTab = (document.getElementById('svActiveTabInput') || {}).value || 'widget';

    if (activeTab === 'widget') {
        var defaults = {
            REFRESH_ENABLED:'1', REFRESH_INTERVAL:'30', WIDGET_MAX_STREAMS:'10',
            WIDGET_SHOW_DEVICE:'1', WIDGET_SHOW_IP:'1', WIDGET_SHOW_PROGRESS:'1',
            WIDGET_SHOW_QUALITY:'1', WIDGET_SHOW_TRANSCODE:'1', WIDGET_SHOW_DETAILS:'1',
            TOOL_ALLOW_KILL:'0',
            VERIFY_SSL:'0'
        };
        Object.keys(defaults).forEach(function(k) {
            var el = form.querySelector('[name="' + k + '"]');
            if (el) el.value = defaults[k];
        });
        markDirty();
        alert('Settings reset to defaults. Click "Apply" to save.');
        return;
    }

    if (activeTab === 'jellyfin') {
        var jfName  = document.getElementById('svJfName');
        var jfUrl   = document.getElementById('svJfUrl');
        var jfToken = document.getElementById('svJfToken');
        var jfRes   = document.getElementById('svJfTestResult');
        if (jfName)  jfName.value  = '';
        if (jfUrl)   jfUrl.value   = '';
        if (jfToken) jfToken.value = '';
        if (jfRes)   jfRes.style.display = 'none';
        return;
    }

    if (activeTab === 'emby') {
        var embyName  = document.getElementById('svEmbyName');
        var embyUrl   = document.getElementById('svEmbyUrl');
        var embyToken = document.getElementById('svEmbyToken');
        var embyRes   = document.getElementById('svEmbyTestResult');
        if (embyName)  embyName.value  = '';
        if (embyUrl)   embyUrl.value   = '';
        if (embyToken) embyToken.value = '';
        if (embyRes)   embyRes.style.display = 'none';
        return;
    }

    if (activeTab === 'plex') {
        // Plex uses OAuth — reset the OAuth UI to initial state
        var step1   = document.getElementById('svPlexOauthStep1');
        var step2   = document.getElementById('svPlexOauthStep2');
        var oauthMsg = document.getElementById('svPlexOauthMsg');
        if (step1) step1.style.display = '';
        if (step2) step2.style.display = 'none';
        if (oauthMsg) oauthMsg.textContent = 'Waiting for you to sign in at plex.tv…';
        return;
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════════════════════════

(function () {

    // ── Load existing servers from PHP ───────────────────────────────────────
    (window.svServers || []).forEach(function(srv, idx) {
        cards.push({
            cardIndex: idx + 1,
            removed:   false,
            data: {
                enabled:           srv.enabled !== false,
                type:              srv.type      || '',
                name:              srv.name      || '',
                url:               srv.url       || '',
                has_token:         srv.has_token  || false,
                token_placeholder: srv.token_placeholder || '',
            },
        });
    });
    renderAllCards();

    // ── Plex OAuth sign-in button ─────────────────────────────────────────
    var plexSignInBtn = document.getElementById('svPlexSignInBtn');
    if (plexSignInBtn) plexSignInBtn.addEventListener('click', startPlexOauth);

    var plexCancelBtn = document.getElementById('svPlexCancelBtn');
    if (plexCancelBtn) plexCancelBtn.addEventListener('click', cancelPlexOauth);


    // ── Jellyfin buttons ────────────────────────────────────────────────────
    var jfTestBtn = document.getElementById('svJfTestBtn');
    var jfAddBtn  = document.getElementById('svJfAddBtn');
    if (jfTestBtn) jfTestBtn.addEventListener('click', testJellyfinServer);
    if (jfAddBtn)  jfAddBtn.addEventListener('click',  addJellyfinServer);

    // ── Emby buttons ─────────────────────────────────────────────────────────
    var embyTestBtn = document.getElementById('svEmbyTestBtn');
    var embyAddBtn  = document.getElementById('svEmbyAddBtn');
    if (embyTestBtn) embyTestBtn.addEventListener('click', testEmbyServer);
    if (embyAddBtn)  embyAddBtn.addEventListener('click',  addEmbyServer);

    // ── Accordion toggles (server lists) ──────────────────────────────────────
    ['svPlexServersAccordionHd','svJfServersAccordionHd','svEmbyServersAccordionHd'].forEach(function(hdId) {
        var hd = document.getElementById(hdId);
        if (!hd) return;
        hd.addEventListener('click', function() {
            var acc = this.closest('.sv-accordion');
            if (acc) acc.classList.toggle('sv-accordion--collapsed');
        });
    });

    // ── Card section toggles (Dashboard Widget panels) ────────────────────────
    document.querySelectorAll('.sv-card-hd--toggle').forEach(function(hd) {
        hd.addEventListener('click', function() {
            var card = this.closest('.sv-card');
            var targetId = this.getAttribute('data-target');
            var bd = targetId ? document.getElementById(targetId) : null;
            if (!bd || !card) return;
            var collapsed = card.classList.contains('sv-card--collapsed');
            card.classList.toggle('sv-card--collapsed', !collapsed);
            bd.style.display = collapsed ? '' : 'none';
        });
    });

    // ── Tab buttons ──────────────────────────────────────────────────────────
    ['Widget', 'Plex', 'Jellyfin', 'Emby'].forEach(function(t) {
        var el = document.getElementById('svTab' + t);
        if (!el) return;
        el.addEventListener('click',   function()  { setTab(t.toLowerCase()); });
        el.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setTab(t.toLowerCase()); } });
    });

    // ── Intercept form submit via AJAX (prevents browser save-password prompt) ──
    var form     = document.querySelector('form[name="streamviewer_settings"]');
    var applyBtn = document.getElementById('svApplyBtn') || (form && form.querySelector('input[name="#apply_btn"]'));

    function ajaxSubmitForm(e) {
        if (e) e.preventDefault();
        syncAllToHidden();

        // Disable apply button while saving
        if (applyBtn) { applyBtn.disabled = true; applyBtn.value = 'Saving…'; }

        // Serialize the form to URL-encoded string (works reliably with Unraid .page files)
        var params = $(form).serialize();
        params += '&%23apply=apply';  // add #apply (URL-encoded)

        $.ajax({
            url:      window.location.pathname,
            method:   'POST',
            data:     params,
            timeout:  15000,
            success: function() {
                var activeTab = 'widget';
                try { activeTab = sessionStorage.getItem('sv_active_tab') || 'widget'; } catch(_) {}
                window.location.href = window.location.href.split('#')[0] + '#' + activeTab;
                window.location.reload();
            },
            error: function(xhr) {
                alert('Save failed (HTTP ' + (xhr.status || '?') + '). Please try again.');
                if (applyBtn) { applyBtn.disabled = false; applyBtn.value = 'Apply'; }
            },
        });

        return false;
    }

    if (applyBtn) {
        applyBtn.addEventListener('mousedown', syncAllToHidden);
        applyBtn.addEventListener('click', ajaxSubmitForm);
    }
    if (form) form.addEventListener('submit', ajaxSubmitForm);

    // ── Reset button ─────────────────────────────────────────────────────────
    var resetBtn = document.getElementById('svResetBtn');
    if (resetBtn) resetBtn.addEventListener('click', resetDefaults);

    // ── Credits modal ────────────────────────────────────────────────────────
    var modal  = document.getElementById('svCreditsModal');
    var cLink  = document.getElementById('svCreditsLink');
    var okBtn  = document.getElementById('svCreditsOkBtn');
    if (cLink && modal) cLink.addEventListener('click', function(e) { e.preventDefault(); modal.style.display = 'flex'; });
    if (okBtn  && modal) okBtn.addEventListener('click', function() { modal.style.display = 'none'; });
    if (modal) {
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') modal.style.display = 'none'; });
    }

    // ── Restore active tab ───────────────────────────────────────────────────
    var hash     = (window.location.hash || '').replace('#', '');
    var postTab  = (document.getElementById('svActiveTabInput') || {}).value || '';
    var savedTab = '';
    try { savedTab = sessionStorage.getItem('sv_active_tab') || ''; } catch(_) {}
    var valid    = ['widget', 'plex', 'jellyfin', 'emby'];
    var target   = valid.includes(hash) ? hash : valid.includes(postTab) ? postTab : valid.includes(savedTab) ? savedTab : 'widget';
    setTab(target);

    // ── FOUC reveal ──────────────────────────────────────────────────────────
    var s = document.querySelector('.streamviewer-settings');
    var c = document.querySelector('.sv-credits-top');
    if (s) s.style.visibility = '';
    if (c) c.style.visibility = '';
})();

})();
</script>
