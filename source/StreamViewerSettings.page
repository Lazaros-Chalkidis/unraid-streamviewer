<?php
require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/streamviewer/streamviewer_api.php';

const SV_PLUGIN      = 'streamviewer';
const SV_CFG_FILE    = '/boot/config/plugins/streamviewer/streamviewer.cfg';
const SV_MAX_SERVERS = 10;
const SV_VALID_TYPES = ['plex', 'jellyfin', 'emby'];

// ── Sanitizers ─────────────────────────────────────────────────────────────

$yn = static fn($v, $d = '0') => ((string)($v ?? $d) === '1') ? '1' : '0';

$sanitize_url = static function($v): string {
    $v = trim((string)($v ?? ''));
    $v = rtrim($v, '/');
    if ($v === '') return '';
    // Accept http(s):// URLs with a valid hostname (including Plex relay hostnames
    // like 84-254-60-132.abc123.plex.direct:23057 which fail filter_var on some PHP builds)
    if (!preg_match('#^https?://[a-zA-Z0-9._\-]+(:[0-9]{1,5})?(/.*)?$#i', $v)) return '';
    return $v;
};

$sanitize_token = static function($v): string {
    $v = trim((string)($v ?? ''));
    // Allow all printable ASCII except quotes/backslash (safe for .cfg file storage)
    return preg_replace('/[^\x20-\x21\x23-\x5B\x5D-\x7E]/u', '', $v);
};

$sanitize_name = static function($v): string {
    $v = trim((string)($v ?? ''));
    return substr(htmlspecialchars($v, ENT_QUOTES, 'UTF-8'), 0, 64);
};

$sanitize_type = static fn($v) => in_array((string)$v, SV_VALID_TYPES, true) ? (string)$v : '';

$clamp_interval = static function($v): string {
    $n = (int)$v;
    return ($n >= 5 && $n <= 300) ? (string)$n : '30';
};

$clamp_max_streams = static function($v): string {
    $allowed = ['0', '5', '10', '20', '50'];
    return in_array((string)$v, $allowed, true) ? (string)$v : '10';
};

// ── Handle POST (Apply) ────────────────────────────────────────────────────

if (isset($_POST['#apply']) || isset($_POST['#apply_btn']) || ($_POST['%23apply'] ?? '') === 'apply') {
    $existing = @parse_plugin_cfg(SV_PLUGIN, true) ?: [];
    $new_cfg  = [];

    for ($i = 1; $i <= SV_MAX_SERVERS; $i++) {
        $enabled = (($_POST["SERVER{$i}_ENABLED"] ?? '0') === '1') ? '1' : '0';
        $type    = $sanitize_type($_POST["SERVER{$i}_TYPE"]  ?? '');
        $name    = $sanitize_name($_POST["SERVER{$i}_NAME"]  ?? '');
        $url     = $sanitize_url($_POST["SERVER{$i}_URL"]    ?? '');
        $token   = $sanitize_token($_POST["SERVER{$i}_TOKEN"] ?? '');

        if ($token === '__KEEP__') {
            $token = (string)($existing["SERVER{$i}_TOKEN"] ?? '');
        }

        $new_cfg["SERVER{$i}_ENABLED"] = $enabled;
        $new_cfg["SERVER{$i}_TYPE"]    = $type;
        $new_cfg["SERVER{$i}_NAME"]    = $name;
        $new_cfg["SERVER{$i}_URL"]     = $url;
        $new_cfg["SERVER{$i}_TOKEN"]   = $token;
    }

    $new_cfg['REFRESH_ENABLED']      = $yn($_POST['REFRESH_ENABLED']      ?? '1', '1');
    $new_cfg['REFRESH_INTERVAL']     = $clamp_interval($_POST['REFRESH_INTERVAL'] ?? 30);
    $new_cfg['WIDGET_MAX_STREAMS']   = $clamp_max_streams($_POST['WIDGET_MAX_STREAMS'] ?? '10');
    $new_cfg['WIDGET_SHOW_IP']       = $yn($_POST['WIDGET_SHOW_IP']       ?? '1', '1');
    $new_cfg['WIDGET_SHOW_PROGRESS'] = $yn($_POST['WIDGET_SHOW_PROGRESS'] ?? '1', '1');
    $new_cfg['WIDGET_SHOW_QUALITY']  = $yn($_POST['WIDGET_SHOW_QUALITY']  ?? '1', '1');
    $new_cfg['WIDGET_SHOW_TRANSCODE']= $yn($_POST['WIDGET_SHOW_TRANSCODE'] ?? '1', '1');
    $new_cfg['WIDGET_SHOW_DETAILS'] = $yn($_POST['WIDGET_SHOW_DETAILS']  ?? '1', '1');
    $new_cfg['WIDGET_SHOW_DEVICE']   = $yn($_POST['WIDGET_SHOW_DEVICE']   ?? '1', '1');

    $new_cfg['TOOL_REFRESH_ENABLED']  = $yn($_POST['TOOL_REFRESH_ENABLED']  ?? '1', '1');
    $new_cfg['TOOL_REFRESH_INTERVAL'] = $clamp_interval($_POST['TOOL_REFRESH_INTERVAL'] ?? 30);
    $new_cfg['TOOL_MAX_STREAMS']      = $clamp_max_streams($_POST['TOOL_MAX_STREAMS'] ?? '0');
    $new_cfg['TOOL_SHOW_IP']          = $yn($_POST['TOOL_SHOW_IP']          ?? '1', '1');
    $new_cfg['TOOL_SHOW_PROGRESS']    = $yn($_POST['TOOL_SHOW_PROGRESS']    ?? '1', '1');
    $new_cfg['TOOL_SHOW_QUALITY']     = $yn($_POST['TOOL_SHOW_QUALITY']     ?? '1', '1');
    $new_cfg['TOOL_SHOW_TRANSCODE']   = $yn($_POST['TOOL_SHOW_TRANSCODE']   ?? '1', '1');
    $new_cfg['TOOL_SHOW_DEVICE']      = $yn($_POST['TOOL_SHOW_DEVICE']      ?? '1', '1');
    $new_cfg['TOOL_ALLOW_KILL']       = $yn($_POST['TOOL_ALLOW_KILL']       ?? '0', '0');
    $new_cfg['VERIFY_SSL']            = $yn($_POST['VERIFY_SSL']            ?? '0', '0');

    $tab = $_POST['sv_active_tab'] ?? 'widget';
    if (!in_array($tab, ['widget', 'plex', 'jellyfin', 'emby'], true)) $tab = 'widget';
    $new_cfg['SV_ACTIVE_TAB'] = $tab;

    $ini = '';
    foreach ($new_cfg as $k => $v) {
        $v   = str_replace('"', '\\"', (string)$v);
        $ini .= "{$k}=\"{$v}\"\n";
    }
    @mkdir(dirname(SV_CFG_FILE), 0755, true);
    $written = file_put_contents(SV_CFG_FILE, $ini);

    // If this is an AJAX request, return JSON and exit
    if (!empty($_SERVER['HTTP_X_REQUESTED_WITH']) || !empty($_POST['_svAjax'])) {
        header('Content-Type: application/json');
        if ($written === false) {
            echo json_encode(['ok' => false, 'error' => 'Could not write config file. Check permissions on ' . SV_CFG_FILE]);
        } else {
            echo json_encode(['ok' => true]);
        }
        exit;
    }

    $cfg = $new_cfg;

} else {
    $cfg = @parse_plugin_cfg(SV_PLUGIN, true) ?: [];
}

// ── Build server data array for JS ────────────────────────────────────────

$servers_data = [];
for ($i = 1; $i <= SV_MAX_SERVERS; $i++) {
    $type  = (string)($cfg["SERVER{$i}_TYPE"]    ?? '');
    $name  = (string)($cfg["SERVER{$i}_NAME"]    ?? '');
    $url   = (string)($cfg["SERVER{$i}_URL"]     ?? '');
    $token = (string)($cfg["SERVER{$i}_TOKEN"]   ?? '');
    $en    = (string)($cfg["SERVER{$i}_ENABLED"] ?? '0');

    if ($type !== '' || $url !== '' || $name !== '') {
        $servers_data[] = [
            'index'             => $i,
            'enabled'           => $en === '1',
            'type'              => $type,
            'name'              => $name,
            'url'               => $url,
            'has_token'         => $token !== '',
            'token_placeholder' => $token !== '' ? '__KEEP__' : '',
        ];
    }
}

$active_tab = (string)($cfg['SV_ACTIVE_TAB'] ?? 'servers');
if (!in_array($active_tab, ['widget', 'plex', 'jellyfin', 'emby'], true)) $active_tab = 'widget';

$plugin_version = 'dev';
$plg = @file_get_contents('/boot/config/plugins/streamviewer/streamviewer.plg');
if ($plg && preg_match('/<ENTITY\s+version\s+"([^"]+)"/i', $plg, $m)) {
    $plugin_version = $m[1];
}
if ($plugin_version === 'dev') {
    $txz_files = glob('/boot/config/plugins/streamviewer/streamviewer-*.txz');
    if ($txz_files && preg_match('/streamviewer-(\d{4}\.\d{2}\.\d{2}[a-z]?)/', basename(end($txz_files)), $m)) {
        $plugin_version = $m[1];
    }
}
?>

