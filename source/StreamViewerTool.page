require_once '/usr/local/emhttp/plugins/dynamix/include/Helpers.php';
require_once '/usr/local/emhttp/plugins/streamviewer/include/streamviewer_api.php';

$cfg = @parse_plugin_cfg('streamviewer', true) ?: [];

$statsEnabled = (($cfg['STATS_ENABLED'] ?? '0') === '1');  // the whole stats UI only renders when recording is on

$svt_active_types = StreamViewerEndpoint::activeServerTypes();  // only show server-type filters for the types actually configured
$svt_type_labels  = ['plex' => 'Plex', 'jellyfin' => 'Jellyfin', 'emby' => 'Emby'];

$dynamix_cfg  = @parse_ini_file('/boot/config/plugins/dynamix/dynamix.cfg', true);
$unraid_theme = $dynamix_cfg['display']['theme'] ?? '';

$svt_light    = in_array($unraid_theme, ['white', 'gray'], true);
$lightClass   = $svt_light ? ' svt-light' : '';

$tile_config = [
    'svToken'         => StreamViewerEndpoint::generateNonce(),
    'statsEnabled'    => $statsEnabled,
    'lightTheme'      => $svt_light,
    'libSectionsOpen' => (($cfg['LIB_SECTIONS_OPEN'] ?? '0') === '1'),
    'activeServerTypes' => StreamViewerEndpoint::activeServerTypes(),
];
$tile_config_json = json_encode($tile_config, JSON_UNESCAPED_SLASHES);

$live_servers = [];
for ($i = 1; $i <= 8; $i++) {
    $enabled = ($cfg["SERVER{$i}_ENABLED"] ?? '0') === '1';
    if (!$enabled) continue;
    $live_servers[] = [
        'index' => $i,
        'name'  => (string)($cfg["SERVER{$i}_NAME"] ?? "Server {$i}"),
        'type'  => (string)($cfg["SERVER{$i}_TYPE"] ?? ''),
    ];
}
$live_interval_sec = max(5, (int)($cfg['LIVE_REFRESH_INTERVAL'] ?? 5));
$live_config = [
    'svToken'             => $tile_config['svToken'],
    'refreshEnabled'      => (($cfg['LIVE_REFRESH_ENABLED']  ?? '1') === '1'),
    'refreshInterval'     => $live_interval_sec * 1000,
    'maxStreams'          => max(0, (int)($cfg['LIVE_MAX_STREAMS'] ?? 0)),
    'showDevice'          => (($cfg['LIVE_SHOW_DEVICE']    ?? '1') === '1'),
    'showIp'              => (($cfg['LIVE_SHOW_IP']        ?? '1') === '1'),
    'showProgress'        => (($cfg['LIVE_SHOW_PROGRESS']  ?? '1') === '1'),
    'showQuality'         => (($cfg['LIVE_SHOW_QUALITY']   ?? '1') === '1'),
    'showTranscode'       => (($cfg['LIVE_SHOW_TRANSCODE'] ?? '1') === '1'),
    'showDetails'         => (($cfg['LIVE_SHOW_DETAILS']   ?? '1') === '1'),
    'showSummary'         => (($cfg['LIVE_SHOW_SUMMARY']   ?? '1') === '1'),
    'showChart'           => (($cfg['LIVE_SHOW_CHART']     ?? '1') === '1'),
    'allowKill'           => (($cfg['LIVE_ALLOW_KILL']     ?? '0') === '1'),
    'servers'             => $live_servers,
    'noServersConfigured' => empty($live_servers),
    'isResponsive'        => true,
    'badgeTheme'          => (string)($cfg['LIVE_BADGE_THEME'] ?? 'default'),
    'largeView'           => true,
];
$live_config_json = json_encode($live_config, JSON_UNESCAPED_SLASHES);
?>

